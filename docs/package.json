{
  "name": "@smoothbricks/lmao-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.40.0",
    "astro": "^6.4.5",
    "sharp": "^0.34.5",
    "starlight-links-validator": "^0.16.0"
  },
  "nx": {
    "name": "lmao-docs",
    "projectType": "application",
    "targets": {
      "astro-html": {
        "command": "astro build",
        "options": { "cwd": "{projectRoot}" },
        "outputs": ["{projectRoot}/dist"],
        "cache": true
      }
    }
  }
}
