{
  "name": "@smoothbricks/lmao-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.0",
    "astro": "^6.2.1",
    "sharp": "^0.34.5",
    "starlight-links-validator": "^0.24.0",
    "starlight-llms-txt": "^0.10.0"
  },
  "nx": {
    "name": "lmao-docs",
    "projectType": "application",
    "targets": {
      "astro-html": {
        "command": "astro build",
        "options": {
          "cwd": "{projectRoot}"
        },
        "outputs": ["{projectRoot}/dist"],
        "cache": true
      }
    }
  }
}
