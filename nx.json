{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "sync": {
    "applyChanges": true
  },
  "tui": {
    "enabled": false
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default"],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "build:node": {
      "cache": true,
      "outputs": ["{projectRoot}/dist-node"]
    },
    "build:ts": {
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/**/*.js",
        "{projectRoot}/dist/**/*.cjs",
        "{projectRoot}/dist/**/*.mjs",
        "{projectRoot}/dist/**/*.jsx",
        "{projectRoot}/dist/**/*.js.map",
        "{projectRoot}/dist/**/*.cjs.map",
        "{projectRoot}/dist/**/*.mjs.map",
        "{projectRoot}/dist/**/*.jsx.map",
        "{projectRoot}/dist/**/*.d.ts",
        "{projectRoot}/dist/**/*.d.cts",
        "{projectRoot}/dist/**/*.d.mts",
        "{projectRoot}/dist/**/*.d.ts.map",
        "{projectRoot}/dist/**/*.d.cts.map",
        "{projectRoot}/dist/**/*.d.mts.map",
        "{projectRoot}/dist/**/*.tsbuildinfo"
      ]
    },
    "build:zig": {
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/**/*.wasm",
        "{projectRoot}/dist/**/*.node",
        "{projectRoot}/dist/**/*.dylib",
        "{projectRoot}/dist/**/*.so",
        "{projectRoot}/dist/**/*.dll",
        "{projectRoot}/dist/**/*.a"
      ]
    },
    "build:zig:ios": {
      "cache": true,
      "outputs": ["{projectRoot}/dist-ios"]
    },
    "build:zig:android": {
      "cache": true,
      "outputs": ["{projectRoot}/dist-android"]
    },
    "build:ts-plugin": {
      "cache": true,
      "outputs": ["{projectRoot}/dist-ts-plugin"]
    },
    "build:wasm": {
      "cache": true,
      "outputs": ["{projectRoot}/dist/**/*.wasm"]
    },
    "typecheck": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/package.json",
        "{projectRoot}/tsconfig*.json",
        "{workspaceRoot}/biome.json",
        "{workspaceRoot}/tooling/checks/**/*"
      ],
      "options": {
        "command": "biome check --files-ignore-unknown=true {projectRoot}",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["typecheck"]
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome format --write --files-ignore-unknown=true {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json",
          "buildDepsName": "build-deps",
          "watchDepsName": "watch-deps"
        }
      }
    }
  ],
  "release": {
    "projectsRelationship": "independent",
    "version": {
      "preVersionCommand": "nx run-many -t build"
    }
  }
}
