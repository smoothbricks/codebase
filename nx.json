{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "sync": {
    "applyChanges": true
  },
  "tui": {
    "enabled": false
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "{projectRoot}/src/**/*",
      "{projectRoot}/package.json",
      "!{projectRoot}/**/__tests__/**",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/**/*.spec.*"
    ],
    "vocabularyArtifacts": [
      "{workspaceRoot}/lmao.vocabulary.config.json",
      "{workspaceRoot}/lmao.vocabulary.json",
      "{workspaceRoot}/tooling/lmao-vocabulary.mjs",
      "{workspaceRoot}/packages/lmao/src/generated/vocabulary.ts",
      "{workspaceRoot}/packages/lmao-rs/crates/lmao-arrow/src/generated/vocabulary.rs",
      "{workspaceRoot}/packages/lmao-ttsc/plugin/**/*.go",
      "{workspaceRoot}/packages/lmao-ttsc/scripts/sync-vocabulary.mjs"
    ],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build",
        "*-js",
        "*-web",
        "*-html",
        "*-css",
        "*-ios",
        "*-android",
        "*-native",
        "*-napi",
        "*-bun",
        "*-wasm"
      ],
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "cache": true,
      "outputs": []
    },
    "typecheck-tests": {
      "cache": true,
      "dependsOn": ["typecheck"],
      "options": {
        "command": "ttsc -p tsconfig.test.json --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["typecheck-tests", "cargo-lint"],
      "inputs": [
        "default",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/bun.lock",
        "{workspaceRoot}/patches/**/*",
        "{workspaceRoot}/biome.json",
        "{workspaceRoot}/eslint.config.ts",
        "{workspaceRoot}/tsconfig.base.json",
        "{workspaceRoot}/tooling/checks/**/*"
      ],
      "options": {
        "commands": ["biome check --files-ignore-unknown=true {projectRoot}", "eslint {projectRoot}/src"],
        "cwd": "{workspaceRoot}",
        "parallel": false
      }
    },
    "clean": {
      "executor": "@smoothbricks/nx-plugin:clean-outputs",
      "cache": false
    }
  },
  "plugins": ["@smoothbricks/nx-plugin"],
  "release": {
    "projects": ["tag:npm:public"],
    "projectsRelationship": "independent",
    "version": {
      "specifierSource": "conventional-commits",
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk",
      "versionActions": "@smoothbricks/nx-plugin/version-actions"
    },
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    },
    "changelog": {
      "automaticFromRef": true,
      "workspaceChangelog": false,
      "projectChangelogs": {
        "createRelease": false,
        "file": false,
        "renderOptions": {
          "authors": true,
          "applyUsernameToAuthors": true
        }
      }
    }
  },
  "analytics": false
}
