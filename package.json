{
  "name": "@smoothbricks/codebase",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@nx/eslint": "23.1.0",
    "@nx/expo": "23.1.0",
    "@nx/js": "23.1.0",
    "@smoothbricks/nx-plugin": "workspace:*",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.32",
    "@swc/helpers": "0.5.21",
    "@types/bun": "1.3.14",
    "@types/node": "~24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^10.2.1",
    "eslint-stdout": "workspace:*",
    "jiti": "^2.7.0",
    "mitata": "^1.0.34",
    "nx": "23.1.0",
    "prettier": "^3.6.1",
    "tslib": "^2.8.1",
    "ttsc": "^0.19.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "verdaccio": "6.5.2"
  },
  "scripts": {
    "build:all": "nx run @smoothbricks/codebase:vocabulary-check && nx run-many -t build",
    "build:watch": "nx run @smoothbricks/codebase:vocabulary-check && nx run-many -t build --watch",
    "clean": "nx run-many -t clean; nx reset",
    "clean:node_modules": "rm -rf node_modules && find e* t* p* -type d -name node_modules -print0 | xargs -0 rm -rvf",
    "clean:trace-db": "find * -name .trace-results.db -delete -print",
    "format:changed": "git-format-staged --config tooling/git-hooks/git-format-staged.yml --also-unstaged",
    "format:staged": "git-format-staged --config tooling/git-hooks/git-format-staged.yml",
    "link:all": "bun run build:all && for pkg in packages/*; do (cd $pkg && bun link); done",
    "lint": "nx run-many -t lint",
    "lint:fix": "git-format-staged --config tooling/git-hooks/git-format-staged.yml --unstaged",
    "list:nx-build-targets": "nx show projects | xargs -n1 nx show project --json | jq -r  '.name as $name | .targets | to_entries[] | \"\\($name):\\(.key)\"'",
    "reload:direnv": "rm -rf tooling/direnv/.{direnv,devenv}; direnv reload",
    "reload:node_modules": "tooling/rm_node_modules; bun install",
    "show:tree": "tree --gitignore -d",
    "unlink:all": "for pkg in packages/*; do (cd $pkg && bun unlink); done",
    "update:devenv": "cd tooling/direnv; devenv update",
    "vocabulary:check": "nx run @smoothbricks/codebase:vocabulary-check",
    "vocabulary:sync": "nx run @smoothbricks/codebase:vocabulary-sync"
  },
  "sherif": {
    "ignoreDependency": [
      "typescript@^6.0.3"
    ]
  },
  "workspaces": [
    "packages/*",
    "tooling"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      },
      "vocabulary-check": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "cache": true,
        "inputs": [
          "vocabularyArtifacts",
          "{workspaceRoot}/packages/lmao-ttsc/examples/**/*.ts",
          "{workspaceRoot}/packages/lmao-ttsc/examples/tsconfig.json",
          "{workspaceRoot}/packages/lmao-ttsc/src/**/*.ts",
          "{workspaceRoot}/packages/lmao-ttsc/tsconfig.test.json"
        ],
        "options": {
          "command": "bun tooling/lmao-vocabulary.mjs check",
          "cwd": "{workspaceRoot}",
          "timeoutMs": 600000,
          "killAfterMs": 10000
        }
      },
      "vocabulary-sync": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "cache": false,
        "options": {
          "command": "bun tooling/lmao-vocabulary.mjs sync",
          "cwd": "{workspaceRoot}",
          "timeoutMs": 600000,
          "killAfterMs": 10000
        }
      }
    },
    "name": "@smoothbricks/codebase"
  },
  "patchedDependencies": {
    "ttsc@0.19.1": "patches/ttsc@0.19.1.patch"
  }
}
