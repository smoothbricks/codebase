{
  "name": "@smoothbricks/codebase",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@nx/eslint": "22.7.1",
    "@nx/expo": "22.7.1",
    "@nx/js": "22.7.1",
    "@smoothbricks/nx-plugin": "workspace:*",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.32",
    "@swc/helpers": "0.5.21",
    "@types/bun": "1.3.13",
    "@types/node": "~24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@typia/unplugin": "^12.0.1",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^10.2.1",
    "eslint-stdout": "workspace:*",
    "mitata": "^1.0.34",
    "nx": "22.7.1",
    "prettier": "^3.6.1",
    "ts-patch": "^3.3.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "typia": "^12.0.1",
    "verdaccio": "6.5.2"
  },
  "scripts": {
    "build:all": "nx run-many -t build",
    "build:watch": "nx run-many -t build --watch",
    "clean:trace-db": "find * -name .trace-results.db -delete -print",
    "format:changed": "git-format-staged --config tooling/git-hooks/git-format-staged.yml --also-unstaged",
    "format:staged": "git-format-staged --config tooling/git-hooks/git-format-staged.yml",
    "link:all": "bun run build:all && for pkg in packages/*; do (cd $pkg && bun link); done",
    "lint": "nx run-many -t lint",
    "lint:fix": "git-format-staged --config tooling/git-hooks/git-format-staged.yml --unstaged",
    "list:nx-build-targets": "nx show projects | xargs -n1 nx show project --json | jq -r  '.name as $name | .targets | to_entries[] | \"\\($name):\\(.key)\"'",
    "prepare": "ts-patch install",
    "reload:direnv": "rm -rf tooling/direnv/.{direnv,devenv}; direnv reload",
    "reload:node_modules": "tooling/rm_node_modules; bun install",
    "show:tree": "tree --gitignore -d",
    "unlink:all": "for pkg in packages/*; do (cd $pkg && bun unlink); done",
    "update:devenv": "cd tooling/direnv; devenv update",
    "update:nixpkgs-overlay": "cd tooling/direnv/nixpkgs-overlay && nix shell nixpkgs#nvfetcher -c nvfetcher",
    "update:npm:interactive": "bunx npm-check-updates -i"
  },
  "workspaces": [
    "packages/*",
    "tooling"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    },
    "name": "@smoothbricks/codebase"
  }
}
