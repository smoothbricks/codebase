{
  "name": "@smoothbricks/arrow-builder",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./arrow": {
      "types": "./dist/lib/arrow/index.d.ts",
      "development": "./src/lib/arrow/index.ts",
      "import": "./dist/lib/arrow/index.js",
      "default": "./dist/lib/arrow/index.js"
    },
    "./schema": {
      "types": "./dist/lib/schema/index.d.ts",
      "development": "./src/lib/schema/index.ts",
      "import": "./dist/lib/schema/index.js",
      "default": "./dist/lib/schema/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@uwdata/flechette": "^2.3.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@smoothbricks/validation": "workspace:*"
  },
  "nx": {
    "sourceRoot": "packages/arrow-builder/src",
    "projectType": "library",
    "targets": {
      "lint": {},
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --build tsconfig.lib.json",
          "cwd": "packages/arrow-builder"
        },
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "arrow-builder"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/arrow-builder"
  },
  "scripts": {
    "test": "nx run arrow-builder:test --tui=false --outputStyle=stream"
  }
}
