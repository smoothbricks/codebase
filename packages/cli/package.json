{
  "name": "@smoothbricks/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "SmoothBricks monorepo automation CLI",
  "bin": {
    "smoo": "./bin/smoo"
  },
  "scripts": {
    "test": "bun test"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./monorepo/runtime": {
      "types": "./dist/monorepo/runtime.d.ts",
      "bun": "./src/monorepo/runtime.ts",
      "development": "./src/monorepo/runtime.ts",
      "import": "./dist/monorepo/runtime.js",
      "default": "./dist/monorepo/runtime.js"
    },
    "./monorepo/git-config": {
      "types": "./dist/monorepo/git-config.d.ts",
      "bun": "./src/monorepo/git-config.ts",
      "development": "./src/monorepo/git-config.ts",
      "import": "./dist/monorepo/git-config.js",
      "default": "./dist/monorepo/git-config.js"
    },
    "./nx-version-actions": {
      "types": "./dist/nx-version-actions.d.cts",
      "require": "./dist/nx-version-actions.cjs",
      "default": "./dist/nx-version-actions.cjs"
    }
  },
  "files": [
    "README.md",
    "bin",
    "dist",
    "managed",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@smoothbricks/validation": "workspace:*",
    "commander": "^14.0.3",
    "publint": "^0.3.18",
    "semver": "^7.7.4",
    "sherif": "^1.11.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "fast-check": "^4.4.0"
  },
  "nx": {
    "targets": {
      "lint": {},
      "typecheck-tests": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit -p tsconfig.test.json",
          "cwd": "packages/cli"
        },
        "dependsOn": [
          "build"
        ]
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "cli"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/cli"
  }
}
