{
  "name": "@smoothbricks/cli",
  "version": "0.10.3",
  "type": "module",
  "description": "SmoothBricks monorepo automation CLI",
  "bin": {
    "smoo": "./bin/smoo"
  },
  "scripts": {
    "test": "nx run cli:test --outputStyle=stream"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./monorepo/runtime": {
      "types": "./dist/monorepo/runtime.d.ts",
      "bun": "./src/monorepo/runtime.ts",
      "development": "./src/monorepo/runtime.ts",
      "import": "./dist/monorepo/runtime.js",
      "default": "./dist/monorepo/runtime.js"
    },
    "./monorepo/git-config": {
      "types": "./dist/monorepo/git-config.d.ts",
      "bun": "./src/monorepo/git-config.ts",
      "development": "./src/monorepo/git-config.ts",
      "import": "./dist/monorepo/git-config.js",
      "default": "./dist/monorepo/git-config.js"
    },
    "./wrangler/prepare-env": {
      "types": "./dist/wrangler/prepare-env.d.ts",
      "bun": "./src/wrangler/prepare-env.ts",
      "development": "./src/wrangler/prepare-env.ts",
      "import": "./dist/wrangler/prepare-env.js",
      "default": "./dist/wrangler/prepare-env.js"
    }
  },
  "files": [
    "README.md",
    "bin",
    "dist",
    "managed",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@prettier/sync": "^0.6.1",
    "@smoothbricks/nx-plugin": "workspace:*",
    "@smoothbricks/validation": "workspace:*",
    "commander": "^14.0.3",
    "prettier": "^3.6.1",
    "publint": "^0.3.18",
    "semver": "^7.7.4",
    "sherif": "^1.11.1",
    "toml-eslint-parser": "^1.0.3",
    "tslib": "^2.8.1",
    "typia": "13.1.1"
  },
  "devDependencies": {
    "fast-check": "^4.4.0"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test --timeout=30000",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "cli"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/cli"
  }
}
