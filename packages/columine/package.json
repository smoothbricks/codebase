{
  "name": "@smoothbricks/columine",
  "version": "0.1.0",
  "description": "Columine - Generic columnar processing pipeline (Parse, Reduce, Compact, Undo) for Arrow column data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wasm": "./dist/columine.wasm"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:zig": "zig build",
    "build:ts": "tsc --build tsconfig.lib.json",
    "build": "bun run build:ts && bun run build:zig",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "typescript": "^5.3.0"
  }
}
