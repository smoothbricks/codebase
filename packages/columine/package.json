{
  "name": "@smoothbricks/columine",
  "version": "0.1.0",
  "description": "Columine - Generic columnar processing pipeline (Parse, Reduce, Compact, Undo) for Arrow column data",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./wasm": "./dist/columine.wasm"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:zig": "zig build",
    "build:ts": "tsc --build tsconfig.lib.json",
    "build": "bun run build:ts && bun run build:zig",
    "test": "bun test src/__tests__/columine-integration.test.ts"
  },
  "nx": {
    "targets": {
      "lint": {},
      "build": {
        "executor": "nx:noop",
        "dependsOn": [
          "^build",
          "build:ts",
          "build:zig"
        ]
      },
      "build:zig": {
        "inputs": [
          "{projectRoot}/src/**/*.zig",
          "{projectRoot}/build.zig",
          "{projectRoot}/build.zig.zon"
        ],
        "outputs": [
          "{projectRoot}/dist/*.wasm"
        ]
      },
      "typecheck": {
        "dependsOn": [
          "build",
          "^typecheck"
        ]
      }
    },
    "tags": [
      "npm:public"
    ]
  },
  "devDependencies": {
    "@smoothbricks/validation": "workspace:*",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/columine"
  }
}
