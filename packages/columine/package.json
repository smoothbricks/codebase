{
  "name": "@smoothbricks/columine",
  "version": "0.1.5-next.0",
  "description": "Columine - Generic columnar processing pipeline (Parse, Reduce, Compact, Undo) for Arrow column data",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./wasm": "./dist/columine.wasm"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.map",
    "dist/**/*.wasm"
  ],
  "scripts": {
    "build:ts": "nx run columine:tsc-js",
    "build": "bun run build:ts && bun run build:wasm",
    "test": "nx run columine:test --outputStyle=stream",
    "build:wasm": "nx run columine:cargo-wasm"
  },
  "nx": {
    "targets": {
      "lint": {},
      "typecheck": {
        "dependsOn": [
          "build",
          "^typecheck"
        ]
      },
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test --timeout=30000 src/__tests__/columine-integration.test.ts",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      },
      "cargo-wasm": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/justfile"
        ],
        "outputs": [
          "{projectRoot}/dist/columine.wasm",
          "{projectRoot}/dist/event_processor.wasm"
        ],
        "options": {
          "commands": [
            "just wasm",
            "just wasm-ep"
          ],
          "cwd": "{projectRoot}",
          "parallel": false
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "columine"
  },
  "devDependencies": {
    "@smoothbricks/validation": "workspace:*",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/columine"
  }
}
