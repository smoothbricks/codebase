{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "skipLibCheck": true,
    "emitDeclarationOnly": false,
    "declaration": true,
    "sourceMap": true,
    "lib": [
      "es2022",
      "dom"
    ],
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.disabled.ts",
    "src/**/*.test.ts",
    "src/**/*.bench.ts"
  ],
  "references": []
}
