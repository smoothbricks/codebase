{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@smoothbricks/validation": ["../validation/src/index.ts"]
    },
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "skipLibCheck": true,
    "emitDeclarationOnly": false,
    "declaration": true,
    "sourceMap": true,
    "lib": ["es2022", "webworker"],
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.disabled.ts",
    "src/**/*.test.ts",
    "src/**/*.bench.ts",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    }
  ]
}
