{
  "name": "@smoothbricks/cowshed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "nx run cowshed:test --outputStyle=stream",
    "build:napi": "nx run cowshed:cargo-napi"
  },
  "nx": {
    "name": "cowshed",
    "targets": {
      "cargo-napi": {
        "executor": "nx:run-commands",
        "cache": true,
        "dependsOn": [
          "^build"
        ],
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/scripts/build-napi.ts"
        ],
        "outputs": [
          "{projectRoot}/dist/cowshed.node"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "command": "bun scripts/build-napi.ts"
        }
      },
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "dependsOn": [
          "cargo-test",
          "cargo-napi",
          "tsc-js",
          "^build",
          "build"
        ],
        "options": {
          "command": "bun test --timeout=30000 src/native.test.ts",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      },
      "integration-apfs": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "cwd": "packages/cowshed",
          "command": "COWSHED_INTEGRATION=1 cargo test -p cowshed-core --test apfs_integration -- --ignored --nocapture"
        }
      },
      "benchmark-apfs": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "cwd": "packages/cowshed",
          "command": "COWSHED_BENCH=1 cargo test --release -p cowshed-core --test apfs_benchmark -- --ignored --nocapture"
        }
      }
    }
  },
  "dependencies": {
    "typia": "13.1.0"
  },
  "devDependencies": {
    "@smoothbricks/lmao": "workspace:*",
    "@smoothbricks/validation": "workspace:*",
    "@types/node": "~24.0.0",
    "typescript": "^7.0.2"
  },
  "description": "Warm git workspaces: instant isolated copy-on-write workspaces with layered sandboxing (CLI, Rust API, NAPI bindings)"
}
