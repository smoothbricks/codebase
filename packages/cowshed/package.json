{
  "name": "@smoothbricks/cowshed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "napi": {
    "binaryName": "cowshed",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "test": "nx run cowshed:test --outputStyle=stream",
    "build:napi": "nx run cowshed:cargo-napi"
  },
  "nx": {
    "name": "cowshed",
    "tags": [
      "ci:skip:test"
    ],
    "targets": {
      "cargo-napi": {
        "executor": "nx:run-commands",
        "cache": true,
        "dependsOn": [
          "^build"
        ],
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/package.json",
          "{workspaceRoot}/bun.lock"
        ],
        "outputs": [
          "{projectRoot}/dist/**/*.node"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "command": "napi build --release --platform --no-js --manifest-path crates/cowshed-napi/Cargo.toml --package cowshed-napi --output-dir dist"
        }
      },
      "napi-arm64-macos": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/package.json",
          "{workspaceRoot}/bun.lock"
        ],
        "outputs": [
          "{projectRoot}/dist/cowshed.darwin-arm64.node"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "command": "napi build --release --platform --no-js --target aarch64-apple-darwin --manifest-path crates/cowshed-napi/Cargo.toml --package cowshed-napi --output-dir dist"
        }
      },
      "napi-x64-macos": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/package.json",
          "{workspaceRoot}/bun.lock"
        ],
        "outputs": [
          "{projectRoot}/dist/cowshed.darwin-x64.node"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "command": "napi build --release --platform --no-js --target x86_64-apple-darwin --manifest-path crates/cowshed-napi/Cargo.toml --package cowshed-napi --output-dir dist"
        }
      },
      "napi-arm64-linux": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/package.json",
          "{workspaceRoot}/bun.lock"
        ],
        "outputs": [
          "{projectRoot}/dist/cowshed.linux-arm64-gnu.node"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "command": "napi build --release --platform --no-js --target aarch64-unknown-linux-gnu --use-napi-cross --manifest-path crates/cowshed-napi/Cargo.toml --package cowshed-napi --output-dir dist"
        }
      },
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "dependsOn": [
          "cargo-test",
          "cargo-napi",
          "tsc-js",
          "^build",
          "build"
        ],
        "options": {
          "command": "bun test --timeout=30000 src/native.test.ts",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      },
      "integration-apfs": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "cwd": "packages/cowshed",
          "command": "COWSHED_INTEGRATION=1 cargo test -p cowshed-core --test apfs_integration -- --ignored --nocapture"
        }
      },
      "benchmark-apfs": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "cwd": "packages/cowshed",
          "command": "COWSHED_BENCH=1 cargo test --release -p cowshed-core --test apfs_benchmark -- --ignored --nocapture"
        }
      }
    }
  },
  "dependencies": {
    "typia": "13.1.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.3",
    "@smoothbricks/lmao": "workspace:*",
    "@smoothbricks/validation": "workspace:*",
    "@types/node": "~26.1.1",
    "typescript": "^6.0.3"
  },
  "description": "Warm git workspaces: instant isolated copy-on-write workspaces with layered sandboxing (CLI, Rust API, NAPI bindings)"
}
