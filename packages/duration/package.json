{
  "name": "@smoothbricks/duration",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "nx run duration:test"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}"
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "duration"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@smoothbricks/validation": "workspace:*"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/duration"
  }
}
