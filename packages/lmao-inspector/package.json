{
  "name": "@smoothbricks/lmao-inspector",
  "version": "0.1.3",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx"
  ],
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev20.0",
    "@uwdata/flechette": "^2.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "tamagui": ">=2.0.0-rc.0"
  },
  "scripts": {
    "test": "nx run lmao-inspector:test --tui=false --outputStyle=stream"
  },
  "devDependencies": {
    "@smoothbricks/lmao": "workspace:*",
    "@smoothbricks/validation": "workspace:*"
  },
  "nx": {
    "sourceRoot": "packages/lmao-inspector/src",
    "projectType": "library",
    "targets": {
      "lint": {},
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test --pass-with-no-tests",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "lmao-inspector"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/lmao-inspector"
  }
}
