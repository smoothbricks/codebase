{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@smoothbricks/validation": ["../validation/src/index.ts"]
    },
    "rootDir": "src",
    "jsx": "react-jsx",
    "types": ["bun"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom"],
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/*.ts",
    "src/**/__tests__/*.tsx",
    "src/**/*.spec.ts",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/test-suite-tracer.ts"
  ],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.lib.json"
    },
    {
      "path": "../lmao/tsconfig.lib.json"
    }
  ]
}
