{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@smoothbricks/validation": ["../validation/src/index.ts"]
    },
    "rootDir": "src",
    "jsx": "react-jsx",
    "types": ["bun"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist-test",
    "tsBuildInfoFile": "dist-test/tsconfig.test.tsbuildinfo"
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/__tests__/*.ts", "src/**/__tests__/*.tsx"],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
