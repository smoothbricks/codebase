# lmao-rs task runner. Install: cargo install just cargo-mutants
# (cd packages/lmao-rs first, or `just -f packages/lmao-rs/justfile <task>`)

# Fast tier: unit + property tests at default case counts (runs the green suite).
test:
    cargo test --workspace

# Heavy property tier: includes the TDD-red #[ignore]d tests and elevated proptest
# cases. Expect failures until the corresponding implementation lands (that's TDD).
proptest-heavy cases="10000":
    PROPTEST_CASES={{cases}} cargo test --workspace --release -- --include-ignored

# Mutation tier (see mutants.toml for arid/exclusion policy).
mutants:
    cargo mutants --workspace

# wasm32 ABI build (allocator.zig replacement). Needs: rustup target add wasm32-unknown-unknown
wasm:
    cargo build -p lmao-wasm --target wasm32-unknown-unknown --release
    mkdir -p dist
    cp target/wasm32-unknown-unknown/release/lmao_wasm.wasm dist/lmao_wasm.wasm
    @ls -la dist/lmao_wasm.wasm

# AxE overhead gates placeholder (criterion). Real gate: traced-vs-untraced ≤20%
# throughput delta + zero-alloc test (tests/alloc_gate.rs, currently TDD-red).
bench:
    cargo bench -p lmao-core

check:
    cargo check --workspace --all-targets
    cargo clippy --workspace --all-targets -- -D warnings

# Proof-only timestamp artifacts consumed by AxE's timestamp accuracy harness.
# WASM preserves the original shared, imported 16-page memory contract; NAPI
# accepts ArrayBuffer directly and is renamed to Node's conventional .node suffix.
timestamp-proof-artifacts:
    LMAO_TIMESTAMP_PROOF_SHARED_MEMORY=1 RUSTC_BOOTSTRAP=1 \
    RUSTFLAGS="-Aunstable-features -Ctarget-feature=+atomics,+bulk-memory,+mutable-globals" \
    cargo build -p lmao-timestamp-proof --target wasm32-unknown-unknown --profile wasm-release \
        -Zbuild-std=core,panic_abort
    cargo build -p lmao-timestamp-proof --features napi --release
    mkdir -p dist/timestamp-accuracy
    cp target/wasm32-unknown-unknown/wasm-release/lmao_timestamp_proof.wasm dist/timestamp-accuracy/span_start.wasm
    @case "$(uname -s)" in \
      Darwin) lib=target/release/liblmao_timestamp_proof.dylib ;; \
      Linux) lib=target/release/liblmao_timestamp_proof.so ;; \
      *) echo "unsupported timestamp-proof NAPI host: $(uname -s)" >&2; exit 1 ;; \
    esac; cp "$lib" dist/timestamp-accuracy/span_start.node
    @ls -la dist/timestamp-accuracy/span_start.wasm dist/timestamp-accuracy/span_start.node
