{
  "name": "@smoothbricks/lmao-rs",
  "version": "0.1.0",
  "private": true,
  "description": "Rust implementation of lmao (Cargo workspace; see crates/)",
  "nx": {
    "name": "lmao-rs",
    "targets": {
      "cargo-wasm": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml"
        ],
        "outputs": [
          "{projectRoot}/dist/**/*.wasm"
        ],
        "options": {
          "command": "cargo build --profile wasm-release --target wasm32-unknown-unknown -p lmao-wasm && mkdir -p dist && cp target/wasm32-unknown-unknown/wasm-release/lmao_wasm.wasm dist/allocator.wasm",
          "cwd": "{projectRoot}"
        },
        "configurations": {
          "development": {
            "command": "cargo build --target wasm32-unknown-unknown -p lmao-wasm && mkdir -p dist && cp target/wasm32-unknown-unknown/debug/lmao_wasm.wasm dist/allocator.wasm"
          }
        }
      },
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "cache": true,
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock"
        ],
        "options": {
          "command": "cargo test --workspace",
          "cwd": "{projectRoot}",
          "timeoutMs": 600000,
          "killAfterMs": 10000
        },
        "configurations": {
          "production": {
            "command": "cargo test --workspace --release"
          }
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "cache": true,
        "dependsOn": [],
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock"
        ],
        "options": {
          "commands": [
            "cargo fmt --all --check",
            "cargo clippy --workspace --all-targets -- -D warnings"
          ],
          "cwd": "{projectRoot}",
          "parallel": false
        }
      },
      "bench": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "command": "cargo bench --workspace",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
