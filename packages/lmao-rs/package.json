{
  "name": "@smoothbricks/lmao-rs",
  "version": "0.1.0",
  "private": true,
  "description": "Rust implementation of lmao (Cargo workspace; see crates/)",
  "nx": {
    "name": "lmao-rs",
    "targets": {
      "lint": {
        "options": {
          "commands": [
            "biome check --files-ignore-unknown=true packages/lmao-rs"
          ],
          "cwd": "",
          "parallel": false
        }
      },
      "cargo-wasm": {
        "executor": "nx:run-commands",
        "cache": true,
        "dependsOn": [
          "^build"
        ],
        "inputs": [
          "{projectRoot}/crates/**/*.rs",
          "{projectRoot}/crates/**/Cargo.toml",
          "{projectRoot}/Cargo.toml",
          "{projectRoot}/Cargo.lock",
          "{projectRoot}/.cargo/config.toml",
          "{projectRoot}/justfile"
        ],
        "outputs": [
          "{projectRoot}/dist/lmao_wasm.wasm"
        ],
        "options": {
          "command": "just wasm",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
