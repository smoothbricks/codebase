{
  "name": "@smoothbricks/lmao-transformer",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "devDependencies": {
    "@smoothbricks/lmao": "workspace:*",
    "@smoothbricks/validation": "workspace:*",
    "@uwdata/flechette": "^2.3.0",
    "typescript": "^5.0.0"
  },
  "nx": {
    "sourceRoot": "packages/lmao-transformer/src",
    "projectType": "library",
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test",
          "cwd": "packages/lmao-transformer"
        }
      }
    },
    "tags": [
      "npm:public"
    ]
  }
}
