{
  "name": "@smoothbricks/lmao-transformer",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "devDependencies": {
    "@smoothbricks/lmao": "workspace:*",
    "@smoothbricks/validation": "workspace:*",
    "@uwdata/flechette": "^2.3.0",
    "typescript": "^5.9.3"
  },
  "nx": {
    "sourceRoot": "packages/lmao-transformer/src",
    "projectType": "library",
    "targets": {
      "lint": {},
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test --parallel=3",
          "cwd": "packages/lmao-transformer"
        }
      }
    },
    "tags": [
      "npm:public"
    ]
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/lmao-transformer"
  }
}
