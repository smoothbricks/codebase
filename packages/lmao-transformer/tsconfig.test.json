{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@smoothbricks/validation": ["packages/validation/src/index.ts"]
    },
    "rootDir": "src",
    "types": ["bun", "node"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist-test",
    "tsBuildInfoFile": "dist-test/tsconfig.test.tsbuildinfo"
  },
  "include": ["src/**/*.test.ts", "src/**/__tests__/*.ts"],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.lib.json"
    },
    {
      "path": "../lmao/tsconfig.lib.json"
    },
    {
      "path": "../arrow-builder/tsconfig.lib.json"
    }
  ]
}
