{
  "name": "@smoothbricks/lmao",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "development": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./es": {
      "development": "./src/es.ts",
      "types": "./dist/es.d.ts",
      "import": "./dist/es.js",
      "default": "./dist/es.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@neophi/sieve-cache": "^1.5.0",
    "@smoothbricks/arrow-builder": "workspace:*",
    "@sury/sury": "npm:@jsr/sury__sury",
    "apache-arrow": "^21.1.0",
    "tslib": "^2.3.0"
  },
  "nx": {
    "sourceRoot": "packages/lmao/src",
    "projectType": "library",
    "targets": {
      "typecheck-tests": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit -p tsconfig.test.json",
          "cwd": "packages/lmao"
        },
        "dependsOn": [
          "build",
          "^build"
        ]
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test",
          "cwd": "packages/lmao"
        }
      }
    },
    "tags": [
      "npm:public"
    ]
  }
}
