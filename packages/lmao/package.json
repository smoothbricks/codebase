{
  "name": "@smoothbricks/lmao",
  "version": "0.1.3",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "development": "./src/node.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./es": {
      "types": "./dist/es.d.ts",
      "development": "./src/es.ts",
      "import": "./dist/es.js",
      "default": "./dist/es.js"
    },
    "./tracers": {
      "types": "./dist/lib/tracers/index.d.ts",
      "development": "./src/lib/tracers/index.ts",
      "import": "./dist/lib/tracers/index.js",
      "default": "./dist/lib/tracers/index.js"
    },
    "./errors": {
      "types": "./dist/lib/errors/index.d.ts",
      "development": "./src/lib/errors/index.ts",
      "import": "./dist/lib/errors/index.js",
      "default": "./dist/lib/errors/index.js"
    },
    "./errors/Blocked": {
      "types": "./dist/lib/errors/Blocked.d.ts",
      "development": "./src/lib/errors/Blocked.ts",
      "import": "./dist/lib/errors/Blocked.js",
      "default": "./dist/lib/errors/Blocked.js"
    },
    "./errors/RetriesExhausted": {
      "types": "./dist/lib/errors/RetriesExhausted.d.ts",
      "development": "./src/lib/errors/RetriesExhausted.ts",
      "import": "./dist/lib/errors/RetriesExhausted.js",
      "default": "./dist/lib/errors/RetriesExhausted.js"
    },
    "./errors/CodeError": {
      "types": "./dist/lib/errors/CodeError.d.ts",
      "development": "./src/lib/errors/CodeError.ts",
      "import": "./dist/lib/errors/CodeError.js",
      "default": "./dist/lib/errors/CodeError.js"
    },
    "./errors/retry-policy": {
      "types": "./dist/lib/errors/retry-policy.d.ts",
      "development": "./src/lib/errors/retry-policy.ts",
      "import": "./dist/lib/errors/retry-policy.js",
      "default": "./dist/lib/errors/retry-policy.js"
    },
    "./errors/Transient": {
      "types": "./dist/lib/errors/Transient.d.ts",
      "development": "./src/lib/errors/Transient.ts",
      "import": "./dist/lib/errors/Transient.js",
      "default": "./dist/lib/errors/Transient.js"
    },
    "./sqlite": {
      "types": "./dist/lib/sqlite/index.d.ts",
      "development": "./src/lib/sqlite/index.ts",
      "import": "./dist/lib/sqlite/index.js",
      "default": "./dist/lib/sqlite/index.js"
    },
    "./sqlite/node": {
      "types": "./dist/lib/sqlite/sqlite-node.d.ts",
      "development": "./src/lib/sqlite/sqlite-node.ts",
      "import": "./dist/lib/sqlite/sqlite-node.js",
      "default": "./dist/lib/sqlite/sqlite-node.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "development": "./src/testing.ts",
      "import": "./dist/testing.js",
      "default": "./dist/testing.js"
    },
    "./testing/bun": {
      "types": "./dist/lib/testing/bun-harness.d.ts",
      "bun": "./src/lib/testing/bun-harness.ts",
      "development": "./src/lib/testing/bun-harness.ts",
      "import": "./dist/lib/testing/bun-harness.js",
      "default": "./dist/lib/testing/bun-harness.js"
    },
    "./testing/vitest": {
      "types": "./dist/lib/testing/vitest-harness.d.ts",
      "development": "./src/lib/testing/vitest-harness.ts",
      "import": "./dist/lib/testing/vitest-harness.js",
      "default": "./dist/lib/testing/vitest-harness.js"
    },
    "./bun/preload": {
      "bun": "./src/bun/preload.ts",
      "development": "./src/bun/preload.ts",
      "default": "./dist/bun/preload.js"
    },
    "./bun/trace-preload": {
      "bun": "./src/bun/trace-preload.ts",
      "development": "./src/bun/trace-preload.ts",
      "default": "./dist/bun/trace-preload.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@neophi/sieve-cache": "^1.5.0",
    "@smoothbricks/arrow-builder": "workspace:*",
    "@smoothbricks/validation": "workspace:*",
    "@uwdata/flechette": "^2.3.0",
    "tslib": "^2.8.1"
  },
  "scripts": {
    "bench": "bun run benchmarks/*.bench.ts",
    "bench:wasm": "bun run benchmarks/js-vs-wasm.bench.ts",
    "build:wasm": "zig build -Doptimize=ReleaseSmall",
    "test": "nx run lmao:test --tui=false --outputStyle=stream"
  },
  "nx": {
    "sourceRoot": "packages/lmao/src",
    "projectType": "library",
    "targets": {
      "lint": {},
      "typecheck": {
        "dependsOn": [
          "build",
          "^typecheck"
        ]
      },
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "lmao"
  },
  "devDependencies": {
    "fast-check": "^4.4.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "vitest": "^3.2.4"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/lmao"
  }
}
