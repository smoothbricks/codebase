{
  "name": "@smoothbricks/lmao",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/lmao/src",
  "projectType": "library",
  "targets": {
    "typecheck-tests": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.test.json",
        "cwd": "packages/lmao"
      },
      "dependsOn": ["build", "^build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test",
        "cwd": "packages/lmao"
      },
      "dependsOn": ["typecheck-tests"]
    }
  },
  "tags": ["npm:public"]
}
