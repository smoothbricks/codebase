{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@smoothbricks/validation": [
        "../validation/src/index.ts"
      ]
    },
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "lib": [
      "es2022",
      "webworker"
    ],
    "skipLibCheck": true,
    "customConditions": []
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    },
    {
      "path": "../arrow-builder/tsconfig.lib.json"
    }
  ]
}
