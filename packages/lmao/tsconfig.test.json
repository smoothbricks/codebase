{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@smoothbricks/validation": ["../validation/src/index.ts"]
    },
    "rootDir": ".",
    "types": ["bun"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "lib": ["es2022", "webworker"],
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/__tests__/*.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/test-suite-tracer.ts",
    "examples/**/*.ts"
  ],
  "references": [
    {
      "path": "../arrow-builder/tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.lib.json"
    },
    {
      "path": "../validation/tsconfig.lib.json"
    }
  ]
}
