{
  "name": "@smoothbricks/nx-plugin",
  "version": "0.2.3-next.0",
  "type": "module",
  "sideEffects": false,
  "main": "./loader.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./loader.js",
      "default": "./loader.js"
    },
    "./version-actions": {
      "types": "./dist/version-actions.d.cts",
      "require": "./dist/version-actions.cjs",
      "default": "./dist/version-actions.cjs"
    },
    "./bounded-test-policy": {
      "types": "./dist/bounded-test-policy.d.ts",
      "development": "./src/bounded-test-policy.ts",
      "import": "./dist/bounded-test-policy.js",
      "default": "./dist/bounded-test-policy.js"
    },
    "./workspace-config-policy": {
      "types": "./dist/workspace-config-policy.d.ts",
      "development": "./src/workspace-config-policy.ts",
      "import": "./dist/workspace-config-policy.js",
      "default": "./dist/workspace-config-policy.js"
    },
    "./release-config-policy": {
      "types": "./dist/release-config-policy.d.ts",
      "development": "./src/release-config-policy.ts",
      "import": "./dist/release-config-policy.js",
      "default": "./dist/release-config-policy.js"
    },
    "./package-target-policy": {
      "types": "./dist/package-target-policy.d.ts",
      "development": "./src/package-target-policy.ts",
      "import": "./dist/package-target-policy.js",
      "default": "./dist/package-target-policy.js"
    },
    "./typecheck-test-policy": {
      "types": "./dist/typecheck-test-policy.d.ts",
      "development": "./src/typecheck-test-policy.ts",
      "import": "./dist/typecheck-test-policy.js",
      "default": "./dist/typecheck-test-policy.js"
    }
  },
  "generators": "./generators.json",
  "executors": "./executors.json",
  "scripts": {
    "test": "nx run nx-plugin:test --outputStyle=stream"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "nx-plugin"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "loader.js",
    "generators.json",
    "executors.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/nx-plugin"
  },
  "dependencies": {
    "@nx/js": "22.7.1",
    "nx": "22.7.1",
    "tslib": "^2.8.1"
  }
}
