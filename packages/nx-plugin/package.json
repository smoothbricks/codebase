{
  "name": "@smoothbricks/nx-plugin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./loader.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "generators": "./generators.json",
  "scripts": {
    "test": "nx run nx-plugin:test"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}"
        }
      }
    },
    "name": "nx-plugin"
  },
  "files": [
    "dist",
    "loader.js",
    "generators.json",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "nx": "22.5.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@smoothbricks/lmao": "workspace:*"
  }
}
