{
  "name": "@smoothbricks/nx-plugin",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./loader.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./loader.js",
      "default": "./loader.js"
    }
  },
  "generators": "./generators.json",
  "scripts": {
    "test": "nx run nx-plugin:test"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}"
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "nx-plugin"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "loader.js",
    "generators.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/nx-plugin"
  },
  "dependencies": {
    "nx": "22.5.4",
    "tslib": "^2.8.1"
  }
}
