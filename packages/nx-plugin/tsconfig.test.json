{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["bun", "node"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist-test",
    "tsBuildInfoFile": "dist-test/tsconfig.test.tsbuildinfo"
