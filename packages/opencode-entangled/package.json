{
  "name": "@smoothbricks/opencode-entangled",
  "version": "0.1.1",
  "description": "OpenCode plugin for Entangled literate programming",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "agents"
  ],
  "scripts": {
    "test": "nx run opencode-entangled:test --outputStyle=stream"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.5",
    "fenceparser": "^2.2.0",
    "typia": "^12.0.1"
  },
  "devDependencies": {
    "@smoothbricks/validation": "workspace:*",
    "typescript": "^6.0.3"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test tests",
          "cwd": "{projectRoot}",
          "timeoutMs": 120000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "opencode-entangled"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/opencode-entangled"
  }
}
