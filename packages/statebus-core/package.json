{
  "name": "@smoothbricks/statebus-core",
  "version": "0.1.1",
  "author": "SmoothBricks Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/statebus-core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bugs": "https://github.com/smoothbricks/statebus/issues",
  "description": "Platform-agnostic core types and runtime for StateBus.",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "homepage": "https://smoothbricks.dev/statebus",
  "keywords": [
    "data flow",
    "event bus",
    "eventbus",
    "observable",
    "reducer",
    "store",
    "state manager",
    "state management",
    "predictable",
    "functional"
  ],
  "license": "MIT",
  "dependencies": {
    "@tldraw/state": "^3.15.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "nx run statebus-core:test --tui=false --outputStyle=stream"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}",
          "timeoutMs": 600000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "statebus-core"
  },
  "publishConfig": {
    "access": "public"
  }
}
