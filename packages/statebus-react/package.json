{
  "name": "@smoothbricks/statebus-react",
  "version": "0.1.1",
  "author": "SmoothBricks Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoothbricks/codebase.git",
    "directory": "packages/statebus-react"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bugs": "https://github.com/smoothbricks/statebus/issues",
  "description": "React bindings and browser scheduler for StateBus.",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "homepage": "https://smoothbricks.dev/statebus",
  "keywords": [
    "data flow",
    "event bus",
    "eventbus",
    "react",
    "react-native",
    "observable",
    "reducer",
    "store",
    "state manager",
    "state management"
  ],
  "license": "MIT",
  "dependencies": {
    "@smoothbricks/statebus-core": "workspace:*",
    "@tldraw/state": "^3.15.5",
    "@tldraw/state-react": "^3.15.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "scripts": {
    "test": "nx run statebus-react:test --tui=false --outputStyle=stream"
  },
  "nx": {
    "targets": {
      "lint": {},
      "test": {
        "executor": "@smoothbricks/nx-plugin:bounded-exec",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}",
          "timeoutMs": 600000,
          "killAfterMs": 10000
        }
      }
    },
    "tags": [
      "npm:public"
    ],
    "name": "statebus-react"
  },
  "publishConfig": {
    "access": "public"
  }
}
