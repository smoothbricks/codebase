{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "types": ["bun"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/__tests__/*.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/test-suite-tracer.ts"
  ],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
