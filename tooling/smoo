#!/usr/bin/env bun
// SmoothBricks self-hosts smoo before @smoothbricks/cli/dist exists.
// Published installs use packages/cli/bin/smoo, which imports built JS.
// Source execution needs the Typia/ttsc Bun preload so createIsParse transforms.
import '@smoothbricks/validation/bun/preload';

const { runCli } = await import('../packages/cli/src/cli.ts');
await runCli();
